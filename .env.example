# Anthropic — server-only. NEVER expose to the client. Used by the comp generation route.
ANTHROPIC_API_KEY=

# Stripe tip — a plain external Payment Link (no SDK). Rendered as a link in a new tab.
# Public payment URL, so it's NEXT_PUBLIC_ (it ships in the client bundle; Results
# reads it via the page's tipUrl prop). Locked link (customer chooses amount):
NEXT_PUBLIC_STRIPE_TIP_URL=https://buy.stripe.com/3cIeVe09Ddt1dBadl70Jq00

# Upstash Redis (Vercel Storage marketplace auto-injects these). Per-IP rate limit + global spend kill-switch.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Public site URL — used for OG/Twitter metadata and the card watermark. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://careerplayercomp.com

# Creator credit link on the results page ("Built by Maurice Peebles").
# Defaults to this LinkedIn if NEXT_PUBLIC_CREATOR_URL is unset.
NEXT_PUBLIC_CREATOR_URL=https://www.linkedin.com/in/mauricepeebles

# B2B "for your team or brand" contact link on the results page.
# TODO(maurice): set to a real intake (form or inbox). Defaults to a mailto placeholder if unset.
NEXT_PUBLIC_CONTACT_URL=mailto:hello@careerplayercomp.com
